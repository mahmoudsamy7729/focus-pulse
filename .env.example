# FocusPulse future environment placeholders.
# Phase 0 documents configuration groups only; no runnable service reads these.

# App
APP_NAME=FocusPulse
APP_ENV=local
APP_DEBUG=true
APP_API_PREFIX=/api/v1

# Auth
AUTH_JWT_SECRET=change-me-in-a-future-phase
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_MINUTES=30

# Database
DATABASE_URL=postgresql+asyncpg://focuspulse:focuspulse@postgres:5432/focuspulse
POSTGRES_DB=focuspulse
POSTGRES_USER=focuspulse
POSTGRES_PASSWORD=focuspulse

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_DEFAULT_QUEUE=focuspulse
CELERY_TASK_ALWAYS_EAGER=false

# AI
AI_PROVIDER=openai
AI_MODEL=placeholder-model
AI_API_KEY=
AI_REQUEST_TIMEOUT_SECONDS=30
AI_MAX_ATTEMPTS=3

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=FocusPulse
